if(@ELIO_PACKAGE_NEEDS_IBVERBS@)
    if(NOT TARGET ibverbs::ibverbs)
        find_library(ELIO_IBVERBS_LIBRARY NAMES ibverbs)
        find_path(ELIO_IBVERBS_INCLUDE_DIR NAMES infiniband/verbs.h)
